@model Website_QuanLyKhoHangThucPham.ViewModels.CategoryViewModel
@{ ViewData["Title"] = "Sửa danh mục"; }
<div class="sc-card" style="max-width:580px;">
  <div class="card-header"><i class="fa fa-pen me-2" style="color:var(--sc-orange);"></i>Chỉnh sửa danh mục</div>
  <div class="p-4">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
      <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control"/><span asp-validation-for="Name" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
      </div>
      <div class="mb-4 form-check">
        <input asp-for="IsActive" class="form-check-input"/>
        <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-sc-primary"><i class="fa fa-save me-1"></i>Cập nhật</button>
        <a asp-action="Index" class="btn btn-sc-outline">Hủy</a>
      </div>
    </form>
  </div>
</div>

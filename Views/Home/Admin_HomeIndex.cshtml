@{ ViewData["Title"] = "Dashboard"; }
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h5 class="fw-bold mb-0">Tổng quan hệ thống</h5>
    <small class="text-muted">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
  </div>
  <div class="d-flex gap-2">
    <a href="/Store" target="_blank" class="btn btn-sc-outline btn-sm">
      <i class="fa fa-store me-1"></i>Xem cửa hàng
    </a>
    <a asp-controller="ImportReceipt" asp-action="Create" class="btn btn-sc-primary btn-sm">
      <i class="fa fa-plus me-1"></i>Lập phiếu nhập
    </a>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-xl-3">
    <div class="sc-card p-3 d-flex align-items-center gap-3">
      <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#f57224,#e65100);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fa fa-box text-white fa-lg"></i>
      </div>
      <div>
        <div style="font-size:1.5rem;font-weight:800;line-height:1;">@ViewBag.TotalProducts</div>
        <div style="font-size:.78rem;color:#888;">Sản phẩm đang bán</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="sc-card p-3 d-flex align-items-center gap-3">
      <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#43a047,#1b5e20);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fa fa-receipt text-white fa-lg"></i>
      </div>
      <div>
        <div style="font-size:1.5rem;font-weight:800;line-height:1;">@ViewBag.TotalOrders</div>
        <div style="font-size:.78rem;color:#888;">Đơn hàng hôm nay</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="sc-card p-3 d-flex align-items-center gap-3">
      <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#ffc107,#f57f17);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fa fa-clock text-white fa-lg"></i>
      </div>
      <div>
        <div style="font-size:1.5rem;font-weight:800;line-height:1;">@ViewBag.PendingExports</div>
        <div style="font-size:.78rem;color:#888;">YC xuất chờ duyệt</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="sc-card p-3 d-flex align-items-center gap-3">
      <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#e53935,#b71c1c);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fa fa-triangle-exclamation text-white fa-lg"></i>
      </div>
      <div>
        <div style="font-size:1.5rem;font-weight:800;line-height:1;">@ViewBag.ExpiringBatches</div>
        <div style="font-size:.78rem;color:#888;">Lô sắp hết hạn</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-xl-8">
    <div class="sc-card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fa fa-chart-bar me-2" style="color:var(--sc-orange);"></i>Doanh thu theo danh mục</span>
        <span style="font-size:.75rem;color:#888;">Dữ liệu kho hiện tại</span>
      </div>
      <div class="p-3">
        @{
          var catSales = ViewBag.CategorySales as List<dynamic> ?? new List<dynamic>();
          var maxVal = catSales.Any() ? (decimal)catSales.Max(c => c.TotalValue) : 1;
        }
        @foreach(var cat in catSales.Take(6)){
          var pct = maxVal > 0 ? (int)((decimal)cat.TotalValue / maxVal * 100) : 0;
          <div class="d-flex align-items-center gap-3 mb-2">
            <div style="width:120px;font-size:.78rem;color:#555;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@cat.CategoryName</div>
            <div style="flex:1;background:#f0f0f0;border-radius:10px;height:20px;overflow:hidden;">
              <div style="height:100%;width:@pct%;background:linear-gradient(135deg,var(--sc-orange),#c0392b);border-radius:10px;transition:.6s;"></div>
            </div>
            <div style="width:90px;text-align:right;font-size:.78rem;font-weight:600;">@((decimal)cat.TotalValue).ToString("N0") ₫</div>
          </div>
        }
        @if(!catSales.Any()){
          <div class="text-center py-3 text-muted small">Chưa có dữ liệu tồn kho</div>
        }
      </div>
    </div>
  </div>
  <div class="col-xl-4">
    <div class="sc-card h-100">
      <div class="card-header"><i class="fa fa-fire me-2 text-danger"></i>Hàng tồn kho thấp</div>
      <div class="p-0">
        @{ var lowStockProducts = ViewBag.LowStockList as List<Website_QuanLyKhoHangThucPham.Models.Product> ?? new(); }
        @if(!lowStockProducts.Any()){
          <div class="p-3 text-center text-muted small"><i class="fa fa-check-circle text-success me-1"></i>Kho đang đủ hàng</div>
        }
        @foreach(var p in lowStockProducts.Take(5)){
          <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom" style="border-color:#f5f5f5!important;">
            <img src="@(p.ImageUrl??"/images/no-image.png")" onerror="this.src='/images/no-image.png'"
                 style="width:32px;height:32px;object-fit:cover;border-radius:6px;"/>
            <div style="flex:1;min-width:0;">
              <div class="text-truncate" style="font-size:.8rem;font-weight:600;">@p.Name</div>
            </div>
            <span class="badge bg-danger">@p.TotalStock @p.Unit</span>
          </div>
        }
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-xl-6">
    <div class="sc-card">
      <div class="card-header d-flex justify-content-between">
        <span><i class="fa fa-file-import me-2" style="color:var(--sc-orange);"></i>Nhập kho gần đây</span>
        <a asp-controller="ImportReceipt" asp-action="Index" style="font-size:.78rem;color:var(--sc-orange);text-decoration:none;">Xem tất cả →</a>
      </div>
      <table class="table sc-table mb-0">
        <thead><tr><th>Mã phiếu</th><th>NCC</th><th>Tổng tiền</th><th>Trạng thái</th></tr></thead>
        <tbody>
        @foreach(var r in (IEnumerable<Website_QuanLyKhoHangThucPham.Models.ImportReceipt>)ViewBag.RecentImports){
          <tr>
            <td><a asp-controller="ImportReceipt" asp-action="Details" asp-route-id="@r.Id" style="color:var(--sc-orange);font-weight:600;">@r.ReceiptCode</a></td>
            <td class="text-truncate" style="max-width:100px;">@r.Supplier?.Name</td>
            <td style="font-weight:600;">@r.TotalAmount.ToString("N0") ₫</td>
            <td><span class="badge @(r.Status==Website_QuanLyKhoHangThucPham.Models.ReceiptStatus.Confirmed?"bg-success":r.Status==Website_QuanLyKhoHangThucPham.Models.ReceiptStatus.Cancelled?"bg-danger":"bg-secondary")">@r.Status</span></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
  <div class="col-xl-6">
    <div class="sc-card">
      <div class="card-header d-flex justify-content-between">
        <span><i class="fa fa-receipt me-2 text-success"></i>Đơn hàng khách gần đây</span>
        <a asp-controller="Payment" asp-action="History" style="font-size:.78rem;color:var(--sc-orange);text-decoration:none;">Xem tất cả →</a>
      </div>
      <table class="table sc-table mb-0">
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th></tr></thead>
        <tbody>
        @foreach(var o in (IEnumerable<Website_QuanLyKhoHangThucPham.Models.StoreOrder>)ViewBag.RecentStoreOrders){
          <tr>
            <td style="font-weight:600;color:var(--sc-orange);">@o.OrderCode</td>
            <td class="text-truncate" style="max-width:100px;">@o.CustomerName</td>
            <td style="font-weight:600;">@o.TotalAmount.ToString("N0") ₫</td>
            <td><span class="badge @(o.Status=="Paid"?"bg-success":o.Status=="COD"?"bg-primary":o.Status=="Cancelled"?"bg-danger":"bg-warning text-dark")">@o.Status</span></td>
          </tr>
        }
        @if(!(ViewBag.RecentStoreOrders as IEnumerable<Website_QuanLyKhoHangThucPham.Models.StoreOrder>)?.Any() ?? true){
          <tr><td colspan="4" class="text-center text-muted py-3">Chưa có đơn hàng</td></tr>
        }
        </tbody>
      </table>
    </div>
  </div>
</div>

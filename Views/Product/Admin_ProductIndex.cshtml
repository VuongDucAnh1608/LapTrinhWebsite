@model Website_QuanLyKhoHangThucPham.ViewModels.PagedResult<Website_QuanLyKhoHangThucPham.Models.Product>
@{ ViewData["Title"] = "Quản lý sản phẩm"; }

<div class="d-flex justify-content-between align-items-center mb-4">
  <div><h5 class="fw-bold mb-0">Quản lý sản phẩm</h5>
  <small class="text-muted">@Model.TotalCount sản phẩm</small></div>
  @if(User.IsInRole("Admin") || User.IsInRole("WarehouseStaff")){
    <a asp-action="Create" class="btn btn-sc-primary btn-sm"><i class="fa fa-plus me-1"></i>Thêm sản phẩm</a>
  }
</div>

<div class="sc-card p-3 mb-3">
  <form method="get" class="d-flex gap-2 flex-wrap align-items-end">
    <div>
      <label class="form-label mb-1">Tìm kiếm</label>
      <input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Tên, SKU..." style="width:200px;"/>
    </div>
    <div>
      <label class="form-label mb-1">Danh mục</label>
      @Html.DropDownList("categoryId",(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Categories,"-- Tất cả --",new{@class="form-select form-select-sm",style="width:160px;"})
    </div>
    <div class="d-flex gap-2 align-self-end">
      <button type="submit" class="btn btn-sc-outline btn-sm"><i class="fa fa-filter me-1"></i>Lọc</button>
      <a asp-action="Index" class="btn btn-sc-outline btn-sm"><i class="fa fa-xmark"></i></a>
    </div>
  </form>
</div>

<div class="sc-card">
  <table class="table sc-table mb-0 align-middle">
    <thead><tr>
      <th>Ảnh</th><th>Tên sản phẩm</th><th>SKU</th><th>Danh mục</th>
      <th class="text-end">Giá bán</th><th class="text-center">Tồn kho</th><th class="text-end">Thao tác</th>
    </tr></thead>
    <tbody>
    @foreach(var p in Model.Items){
    <tr>
      <td><img src="@(p.ImageUrl??"/images/no-image.png")" onerror="this.src='/images/no-image.png'"
               style="width:40px;height:40px;object-fit:cover;border-radius:6px;border:1px solid #f0f0f0;"/></td>
      <td>
        <div class="fw-semibold">@p.Name</div>
        <div style="font-size:.75rem;color:#888;">@p.Supplier?.Name</div>
      </td>
      <td><code style="font-size:.78rem;">@p.SKU</code></td>
      <td><span class="badge bg-light text-dark border" style="font-size:.75rem;">@p.Category?.Name</span></td>
      <td class="text-end fw-semibold" style="color:var(--sc-orange);">@p.SellPrice.ToString("N0") ₫</td>
      <td class="text-center">
        <span class="badge @(p.TotalStock==0?"bg-danger":p.IsLowStock?"bg-warning text-dark":"bg-success")">
          @p.TotalStock @p.Unit
        </span>
      </td>
      <td class="text-end">
        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-sc-outline me-1"><i class="fa fa-eye"></i></a>
        @if(User.IsInRole("Admin")||User.IsInRole("WarehouseStaff")){
          <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-sc-outline me-1"><i class="fa fa-pen"></i></a>
          <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa sản phẩm này?')">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i></button>
          </form>
        }
      </td>
    </tr>
    }
    </tbody>
  </table>
</div>

@if(Model.TotalPages > 1){
<nav class="mt-3 d-flex justify-content-center">
  <ul class="pagination pagination-sm">
    @for(int i=1;i<=Model.TotalPages;i++){
      <li class="page-item @(i==Model.Page?"active":"")">
        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search" asp-route-categoryId="@ViewBag.CategoryId">@i</a>
      </li>
    }
  </ul>
</nav>
}

@model Website_QuanLyKhoHangThucPham.ViewModels.PagedResult<Website_QuanLyKhoHangThucPham.Models.ExportRequest>
@{ ViewData["Title"] = "Yêu cầu xuất kho"; }
<div class="d-flex justify-content-between align-items-center mb-3">
<h4 class="fw-bold mb-0"><i class="fa fa-file-export me-2 text-primary"></i>Quản lý yêu cầu xuất kho</h4>
</div>
<div class="card"><div class="card-body p-0">
<table class="table table-hover mb-0 align-middle">
<thead class="table-light"><tr><th>Mã YC</th><th>Người yêu cầu</th><th>Ngày YC</th><th>Số SP</th><th>Trạng thái</th><th>Người xử lý</th><th class="text-end">Thao tác</th></tr></thead>
<tbody>
@foreach(var r in Model.Items){
<tr>
<td class="fw-semibold"><a asp-action="Details" asp-route-id="@r.Id">@r.RequestCode</a></td>
<td>@r.RequestedBy?.FullName</td>
<td>@r.RequestDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
<td><span class="badge bg-secondary">@r.Details.Count SP</span></td>
<td><span class="badge @(r.Status==Website_QuanLyKhoHangThucPham.Models.ExportStatus.Completed?"bg-success":r.Status==Website_QuanLyKhoHangThucPham.Models.ExportStatus.Rejected?"bg-danger":r.Status==Website_QuanLyKhoHangThucPham.Models.ExportStatus.Pending?"bg-warning text-dark":"bg-secondary")">@r.Status</span></td>
<td>@r.ProcessedBy?.FullName</td>
<td class="text-end">
<a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info me-1"><i class="fa fa-eye"></i></a>
@if(r.Status==Website_QuanLyKhoHangThucPham.Models.ExportStatus.Pending){
<a asp-action="Process" asp-route-id="@r.Id" class="btn btn-sm btn-success me-1"><i class="fa fa-check me-1"></i>Duyệt</a>
<button class="btn btn-sm btn-outline-danger btn-reject" data-id="@r.Id"><i class="fa fa-xmark me-1"></i>Từ chối</button>
}
</td>
</tr>
}
</tbody>
</table>
</div></div>
@if(Model.TotalPages>1){
<nav class="mt-3 d-flex justify-content-center"><ul class="pagination pagination-sm">
@for(int i=1;i<=Model.TotalPages;i++){<li class="page-item @(i==Model.Page?"active":"")"><a class="page-link" asp-action="Index" asp-route-page="@i">@i</a></li>}
</ul></nav>
}
<div class="modal fade" id="rejectModal" tabindex="-1">
<div class="modal-dialog"><div class="modal-content">
<div class="modal-header"><h5 class="modal-title">Từ chối yêu cầu</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<form id="rejectForm" method="post">
@Html.AntiForgeryToken()
<div class="modal-body"><div class="mb-3"><label class="form-label fw-semibold">Lý do từ chối</label>
<textarea name="reason" class="form-control" rows="3" required placeholder="Nhập lý do..."></textarea></div></div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
<button type="submit" class="btn btn-danger">Xác nhận từ chối</button></div>
</form>
</div></div></div>
@section Scripts {
<script>
document.querySelectorAll('.btn-reject').forEach(btn=>{
btn.addEventListener('click',function(){
document.getElementById('rejectForm').action='/ExportRequest/Reject/'+this.dataset.id;
new bootstrap.Modal(document.getElementById('rejectModal')).show();
});
});
</script>
}

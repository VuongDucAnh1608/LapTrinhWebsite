@model Website_QuanLyKhoHangThucPham.Models.ExportRequest
@{ ViewData["Title"] = "Chi tiết yêu cầu xuất"; }
<div class="card mb-3">
<div class="card-header d-flex justify-content-between align-items-center">
<h5 class="mb-0 fw-bold">@Model.RequestCode</h5>
<span class="badge fs-6 @(Model.Status==Website_QuanLyKhoHangThucPham.Models.ExportStatus.Completed?"bg-success":Model.Status==Website_QuanLyKhoHangThucPham.Models.ExportStatus.Rejected?"bg-danger":"bg-warning text-dark")">@Model.Status</span>
</div>
<div class="card-body"><div class="row g-3">
<div class="col-md-3"><small class="text-muted">Người yêu cầu</small><div class="fw-semibold">@Model.RequestedBy?.FullName</div></div>
<div class="col-md-3"><small class="text-muted">Ngày yêu cầu</small><div class="fw-semibold">@Model.RequestDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
@if(Model.ProcessedBy!=null){
<div class="col-md-3"><small class="text-muted">Người xử lý</small><div class="fw-semibold">@Model.ProcessedBy.FullName</div></div>
<div class="col-md-3"><small class="text-muted">Ngày xử lý</small><div class="fw-semibold">@Model.ProcessedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
}
@if(!string.IsNullOrEmpty(Model.Note)){<div class="col-12"><small class="text-muted">Ghi chú</small><div>@Model.Note</div></div>}
@if(!string.IsNullOrEmpty(Model.RejectionReason)){<div class="col-12"><small class="text-muted">Lý do từ chối</small><div class="text-danger fw-semibold">@Model.RejectionReason</div></div>}
</div></div></div>
<div class="card"><div class="card-header fw-semibold"><i class="fa fa-list me-2"></i>Chi tiết sản phẩm</div>
<div class="card-body p-0">
<table class="table mb-0">
<thead class="table-light"><tr><th>#</th><th>Sản phẩm</th><th class="text-end">SL yêu cầu</th><th class="text-end">SL xuất thực tế</th></tr></thead>
<tbody>
@{ int stt=1; }
@foreach(var d in Model.Details){
<tr><td>@stt++</td><td class="fw-semibold">@d.Product?.Name</td>
<td class="text-end">@d.RequestedQuantity</td>
<td class="text-end @(d.ActualQuantity.HasValue?"fw-semibold text-success":"text-muted")">@(d.ActualQuantity.HasValue?d.ActualQuantity.ToString():"—")</td>
</tr>
}
</tbody>
</table>
</div></div>
<div class="mt-3"><a asp-action="Index" class="btn btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Quay lại</a></div>

@model Website_QuanLyKhoHangThucPham.ViewModels.ExportRequestViewModel
@{ ViewData["Title"] = "Tạo yêu cầu xuất kho"; }
<div class="card">
<div class="card-header fw-semibold"><i class="fa fa-file-export me-2"></i>Tạo yêu cầu xuất kho mới</div>
<div class="card-body">
<form asp-action="Create" method="post" id="exportForm">
@Html.AntiForgeryToken()
<div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
<div class="mb-4">
<label class="form-label fw-semibold">Lý do / Ghi chú</label>
<textarea name="Note" class="form-control" rows="2" placeholder="Mục đích xuất hàng..."></textarea>
</div>
<div class="d-flex justify-content-between align-items-center mb-3">
<h6 class="fw-bold mb-0">Danh sách sản phẩm cần xuất</h6>
<button type="button" class="btn btn-sm btn-success" id="addRow"><i class="fa fa-plus me-1"></i>Thêm sản phẩm</button>
</div>
<div class="table-responsive">
<table class="table table-bordered align-middle" id="detailTable">
<thead class="table-light"><tr><th>Sản phẩm</th><th style="width:120px">Số lượng</th><th>Ghi chú dòng</th><th style="width:40px"></th></tr></thead>
<tbody id="detailBody">
<tr class="detail-row">
<td><input name="Details[0].ProductId" type="hidden" class="product-id"/>
<input class="form-control form-control-sm product-search" placeholder="Tìm sản phẩm..." autocomplete="off"/></td>
<td><input name="Details[0].RequestedQuantity" class="form-control form-control-sm" type="number" min="1" value="1" required/></td>
<td><input name="Details[0].Note" class="form-control form-control-sm" placeholder="Ghi chú..."/></td>
<td><button type="button" class="btn btn-sm btn-outline-danger remove-row"><i class="fa fa-trash"></i></button></td>
</tr>
</tbody>
</table>
</div>
<div class="mt-4 d-flex gap-2">
<button type="submit" class="btn btn-primary"><i class="fa fa-paper-plane me-2"></i>Gửi yêu cầu</button>
<a asp-action="MyRequests" class="btn btn-outline-secondary">Hủy</a>
</div>
</form>
</div></div>
@section Scripts {
<script>
let rowIdx = 1;
document.getElementById('addRow').addEventListener('click', () => {
    const newRow = document.querySelector('.detail-row').cloneNode(true);
    newRow.querySelectorAll('[name]').forEach(el => {
        el.name = el.name.replace(/\[\d+\]/, '[' + rowIdx + ']');
        if(el.type!=='number') el.value = '';
    });
    document.getElementById('detailBody').appendChild(newRow);
    initAC(newRow.querySelector('.product-search'));
    rowIdx++;
});
document.addEventListener('click', e => {
    if(e.target.closest('.remove-row')){
        const rows=document.querySelectorAll('.detail-row');
        if(rows.length>1) e.target.closest('tr').remove();
    }
});
function initAC(inp) {
    inp.addEventListener('input', async function() {
        if(this.value.length<1) return;
        const r = await fetch('/Product/Autocomplete?term='+encodeURIComponent(this.value));
        const d = await r.json();
        let list = document.getElementById('prod-dl') || (() => { const dl=document.createElement('datalist'); dl.id='prod-dl'; document.body.appendChild(dl); return dl; })();
        list.innerHTML = d.map(p=>`<option value="${p.label}" data-id="${p.id}">`).join('');
        this.setAttribute('list','prod-dl');
    });
    inp.addEventListener('change', function() {
        const opt = [...document.querySelectorAll('#prod-dl option')].find(o=>o.value===this.value);
        if(opt) this.closest('tr').querySelector('.product-id').value = opt.dataset.id;
    });
}
document.querySelectorAll('.product-search').forEach(initAC);
</script>
}

@model Website_QuanLyKhoHangThucPham.Models.StoreOrder
@{ ViewData["Title"] = "Theo dõi đơn hàng"; Layout = "~/Views/Shared/Customer_Layout.cshtml"; }

<div class="container my-4" style="max-width:680px;">

  <h5 class="fw-bold mb-3"><i class="fa fa-magnifying-glass me-2 text-primary"></i>Theo dõi đơn hàng</h5>

  @{ var recentOrders = ViewBag.RecentOrders as List<Website_QuanLyKhoHangThucPham.Models.StoreOrder>; }

  @if (Model == null && recentOrders != null) {
    @if (recentOrders.Any()) {
      <p class="text-muted small mb-3">Đơn hàng bạn đã mua trong 7 ngày qua — bấm vào đơn để xem chi tiết, không cần nhớ mã đơn hàng.</p>
      @foreach (var o in recentOrders) {
      <a asp-action="TrackOrder" asp-route-orderCode="@o.OrderCode" class="card mb-2 text-decoration-none text-dark">
        <div class="card-body d-flex justify-content-between align-items-center py-2">
          <div>
            <div class="fw-bold text-success" style="letter-spacing:1px;font-size:.9rem;">@o.OrderCode</div>
            <div class="text-muted small">@o.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy") · @o.Items.Count sản phẩm</div>
          </div>
          <div class="text-end">
            <div class="fw-bold text-danger small">@o.TotalAmount.ToString("N0") ₫</div>
            <span class="badge @(o.Status=="Paid"?"bg-success":o.Status=="COD"?"bg-primary":o.Status=="Cancelled"?"bg-danger":"bg-warning text-dark")" style="font-size:.7rem;">
              @(o.Status=="Paid"?"Đã thanh toán":o.Status=="COD"?"Chờ nhận hàng":o.Status=="Cancelled"?"Đã hủy":"Chờ thanh toán")
            </span>
          </div>
        </div>
      </a>
      }
    } else {
      <div class="card text-center py-4 mb-3">
        <div class="text-muted small"><i class="fa fa-box-open fa-2x mb-2 d-block text-secondary"></i>Bạn chưa có đơn hàng nào trong 7 ngày qua.</div>
      </div>
    }
  } else if (Model == null) {
  <div class="card mb-3">
    <div class="card-body">
      <form method="get" asp-action="TrackOrder" class="d-flex gap-2">
        <input name="orderCode" class="form-control" placeholder="Nhập mã đơn hàng (VD: WH20260611063022)"
               value="@Model?.OrderCode" style="font-family:monospace;"/>
        <button type="submit" class="btn btn-primary px-4">
          <i class="fa fa-search me-1"></i>Tra cứu
        </button>
      </form>
      <div class="form-text mt-2"><i class="fa fa-circle-info me-1"></i>Đăng nhập để xem nhanh đơn hàng gần đây mà không cần nhớ mã.</div>
    </div>
  </div>
  }

  @if (Model != null) {
  <div class="card">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <div class="text-muted small">Mã đơn hàng</div>
          <div class="fw-bold fs-5 text-success" style="letter-spacing:1px;">@Model.OrderCode</div>
          <div class="text-muted small mt-1">Đặt lúc: @Model.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</div>
        </div>
        <span class="badge fs-6 @(Model.Status=="Paid"?"bg-success":Model.Status=="COD"?"bg-primary":Model.Status=="Cancelled"?"bg-danger":"bg-warning text-dark")">
          @(Model.Status == "Paid" ? "Đã thanh toán"
          : Model.Status == "COD"  ? "Chờ nhận hàng"
          : Model.Status == "Cancelled" ? "Đã hủy"
          : "Chờ thanh toán")
        </span>
      </div>

      <div class="row g-2 mb-3">
        <div class="col-6">
          <div class="bg-light rounded p-2 small">
            <div class="text-muted">Khách hàng</div>
            <div class="fw-semibold">@Model.CustomerName</div>
            <div>@Model.CustomerPhone</div>
          </div>
        </div>
        <div class="col-6">
          <div class="bg-light rounded p-2 small">
            <div class="text-muted">Thanh toán</div>
            <div class="fw-semibold">@(Model.PaymentMethod == "COD" ? "Tiền mặt khi nhận" : "Chuyển khoản QR")</div>
            @if(Model.PaidAt.HasValue){
            <div class="text-success">@Model.PaidAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</div>
            }
          </div>
        </div>
        @if(!string.IsNullOrEmpty(Model.DeliveryAddress)){
        <div class="col-12">
          <div class="bg-light rounded p-2 small">
            <div class="text-muted">Địa chỉ giao hàng</div>
            <div class="fw-semibold">@Model.DeliveryAddress</div>
          </div>
        </div>
        }
      </div>

      @if(Model.Items?.Any() == true){
      <div class="border rounded overflow-hidden mb-3">
        <div class="bg-light px-3 py-2 small fw-bold text-muted">CHI TIẾT ĐƠN HÀNG</div>
        @foreach(var item in Model.Items){
        <div class="px-3 py-2 border-top d-flex align-items-center gap-2">
          <img src="@(item.Product?.ImageUrl??"/images/no-image.png")" onerror="this.src='/images/no-image.png'"
               style="width:40px;height:40px;object-fit:cover;border-radius:6px;flex-shrink:0;"/>
          <div style="flex:1;">
            <div class="small fw-semibold">@item.ProductName</div>
            <div class="text-muted" style="font-size:.75rem;">x@(item.Quantity)</div>
          </div>
          <div class="text-danger fw-bold small">@item.SubTotal.ToString("N0") ₫</div>
        </div>
        }
        <div class="px-3 py-2 border-top d-flex justify-content-between bg-light">
          <span class="fw-bold">Tổng cộng</span>
          <span class="fw-bold text-danger fs-6">@Model.TotalAmount.ToString("N0") ₫</span>
        </div>
      </div>
      }

      <a href="/Store" class="btn btn-primary w-100">
        <i class="fa fa-store me-2"></i>Tiếp tục mua sắm
      </a>
    </div>
  </div>
  } else if (ViewBag.NotFound == true) {
    <div class="alert alert-warning">
      <i class="fa fa-exclamation-circle me-2"></i>Không tìm thấy đơn hàng với mã đã nhập. Vui lòng kiểm tra lại.
    </div>
  }
</div>

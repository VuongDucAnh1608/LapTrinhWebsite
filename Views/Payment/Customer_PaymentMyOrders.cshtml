@model IEnumerable<Website_QuanLyKhoHangThucPham.Models.StoreOrder>
@{ ViewData["Title"] = "Đơn hàng của tôi"; Layout = "~/Views/Shared/Customer_Layout.cshtml"; }

<div class="container my-4" style="max-width:800px;">
  <h5 class="fw-bold mb-4"><i class="fa fa-box me-2 text-success"></i>Đơn hàng của tôi</h5>

  @if (!Model.Any()) {
  <div class="card text-center py-5">
    <div class="text-muted">
      <i class="fa fa-box-open fa-3x mb-3 d-block text-secondary"></i>
      Bạn chưa có đơn hàng nào.
      <div class="mt-3">
        <a href="/Store" class="btn btn-primary"><i class="fa fa-store me-2"></i>Mua sắm ngay</a>
      </div>
    </div>
  </div>
  } else {
  @foreach (var order in Model) {
  <div class="card mb-3">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
          <div class="text-muted small">Mã đơn hàng</div>
          <div class="fw-bold text-success" style="letter-spacing:1px;">@order.OrderCode</div>
          <div class="text-muted small">@order.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</div>
        </div>
        <span class="badge fs-6 @(order.Status=="Paid"?"bg-success":order.Status=="COD"?"bg-primary":order.Status=="Cancelled"?"bg-danger":"bg-warning text-dark")">
          @(order.Status=="Paid"?"Đã thanh toán":order.Status=="COD"?"Chờ nhận hàng":order.Status=="Cancelled"?"Đã hủy":"Chờ thanh toán")
        </span>
      </div>

      @foreach (var item in order.Items) {
      <div class="d-flex align-items-center gap-2 mb-2 pb-2 border-bottom">
        <div style="flex:1;">
          <div class="small fw-semibold">@item.ProductName</div>
          <div class="text-muted" style="font-size:.75rem;">x@(item.Quantity) · @item.UnitPrice.ToString("N0") ₫</div>
        </div>
        <div class="text-danger fw-bold small">@((item.Quantity * item.UnitPrice).ToString("N0")) ₫</div>
      </div>
      }

      <div class="d-flex justify-content-between align-items-center mt-2">
        <span class="fw-bold">Tổng: <span class="text-danger">@order.TotalAmount.ToString("N0") ₫</span></span>
        <a href="/Payment/TrackOrder?orderCode=@order.OrderCode" class="btn btn-sm btn-outline-primary">
          <i class="fa fa-eye me-1"></i>Chi tiết
        </a>
      </div>
    </div>
  </div>
  }
  }
</div>

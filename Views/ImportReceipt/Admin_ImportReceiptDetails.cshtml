@model Website_QuanLyKhoHangThucPham.Models.ImportReceipt
@{ ViewData["Title"] = "Chi tiết phiếu nhập"; }
<div class="card mb-3">
<div class="card-header d-flex justify-content-between align-items-center">
<h5 class="mb-0 fw-bold">Phiếu nhập: @Model.ReceiptCode</h5>
<span class="badge fs-6 @(Model.Status==Website_QuanLyKhoHangThucPham.Models.ReceiptStatus.Confirmed?"bg-success":Model.Status==Website_QuanLyKhoHangThucPham.Models.ReceiptStatus.Cancelled?"bg-danger":"bg-secondary")">@Model.Status</span>
</div>
<div class="card-body">
<div class="row g-3">
<div class="col-md-3"><small class="text-muted">Mã phiếu</small><div class="fw-semibold">@Model.ReceiptCode</div></div>
<div class="col-md-3"><small class="text-muted">Ngày nhập</small><div class="fw-semibold">@Model.ImportDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
<div class="col-md-3"><small class="text-muted">Nhà cung cấp</small><div class="fw-semibold">@Model.Supplier?.Name</div></div>
<div class="col-md-3"><small class="text-muted">Người lập</small><div class="fw-semibold">@Model.CreatedBy?.FullName</div></div>
@if(Model.Status==Website_QuanLyKhoHangThucPham.Models.ReceiptStatus.Confirmed){
<div class="col-md-3"><small class="text-muted">Xác nhận bởi</small><div class="fw-semibold">@Model.ConfirmedBy?.FullName</div></div>
<div class="col-md-3"><small class="text-muted">Ngày xác nhận</small><div class="fw-semibold">@Model.ConfirmedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
}
@if(!string.IsNullOrEmpty(Model.Note)){<div class="col-12"><small class="text-muted">Ghi chú</small><div>@Model.Note</div></div>}
</div>
</div></div>
<div class="card">
<div class="card-header fw-semibold"><i class="fa fa-list me-2"></i>Chi tiết sản phẩm</div>
<div class="card-body p-0">
<table class="table table-hover mb-0">
<thead class="table-light"><tr><th>#</th><th>Sản phẩm</th><th>Mã lô</th><th>Ngày SX</th><th>Hạn SD</th><th class="text-end">SL</th><th class="text-end">Đơn giá</th><th class="text-end">Thành tiền</th></tr></thead>
<tbody>
@{ int stt=1; }
@foreach(var d in Model.Details){
<tr>
<td>@stt++</td>
<td><span class="fw-semibold">@d.Product?.Name</span><br/><small class="text-muted">@d.Product?.Category?.Name</small></td>
<td><span class="badge bg-light text-dark border">@d.BatchCode</span></td>
<td>@d.ManufactureDate.ToString("dd/MM/yyyy")</td>
<td class="@(d.ExpiryDate<=DateTime.UtcNow.AddDays(30)?"text-warning fw-semibold":"")">@d.ExpiryDate.ToString("dd/MM/yyyy")</td>
<td class="text-end">@d.Quantity @d.Product?.Unit</td>
<td class="text-end">@d.UnitPrice.ToString("N0") ₫</td>
<td class="text-end fw-semibold">@d.SubTotal.ToString("N0") ₫</td>
</tr>
}
</tbody>
<tfoot class="table-light"><tr>
<td colspan="7" class="text-end fw-bold">Tổng cộng:</td>
<td class="text-end fw-bold text-primary fs-6">@Model.TotalAmount.ToString("N0") ₫</td>
</tr></tfoot>
</table>
</div></div>
<div class="mt-3 d-flex gap-2">
<a asp-action="Index" class="btn btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Quay lại</a>
</div>

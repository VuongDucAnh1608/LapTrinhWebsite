<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@ViewData["Title"] — DokiDoki Seller Center</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
:root{--sc-bg:#f0f2f5;--sc-sidebar:#fff;--sc-topbar:#fff;--sc-orange:#2196F3;--sc-text:#2c3e50;--sc-border:#e8ecef;}
*{box-sizing:border-box;}body{background:var(--sc-bg);font-family:'Segoe UI',sans-serif;font-size:13.5px;color:var(--sc-text);}

.sc-sidebar{width:230px;min-height:100vh;background:var(--sc-sidebar);position:fixed;top:0;left:0;z-index:200;border-right:1px solid var(--sc-border);display:flex;flex-direction:column;}
.sc-logo{padding:16px 20px;border-bottom:1px solid var(--sc-border);display:flex;align-items:center;gap:10px;}
.sc-logo-icon{width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#2196F3,#1565C0);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.9rem;}
.sc-logo-text{font-weight:800;font-size:.95rem;color:var(--sc-text);}
.sc-logo-text span{color:var(--sc-orange);}
.sc-logo small{color:#888;font-size:.68rem;display:block;margin-top:1px;}
.sc-nav{flex:1;overflow-y:auto;padding:10px 0;}
.sc-group{padding:6px 16px 2px;font-size:.66rem;color:#aaa;font-weight:700;text-transform:uppercase;letter-spacing:.08em;}
.sc-link{display:flex;align-items:center;gap:10px;padding:8px 20px;color:#555;text-decoration:none;font-size:.83rem;border-left:3px solid transparent;transition:all .15s;margin:1px 0;}
.sc-link:hover{background:#fef9f6;color:var(--sc-orange);border-left-color:var(--sc-orange);}
.sc-link.active{background:#fef5f0;color:var(--sc-orange);border-left-color:var(--sc-orange);font-weight:600;}
.sc-link .sc-icon{width:20px;text-align:center;color:inherit;}
.sc-badge{background:var(--sc-orange);color:#fff;border-radius:10px;padding:1px 7px;font-size:.68rem;font-weight:700;margin-left:auto;}
.sc-user{padding:12px 16px;border-top:1px solid var(--sc-border);display:flex;align-items:center;gap:10px;}
.sc-user-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#2196F3,#1565C0);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0;}
.sc-user-name{font-size:.8rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sc-user-role{font-size:.7rem;color:#888;}

.sc-main{margin-left:230px;min-height:100vh;display:flex;flex-direction:column;}
.sc-topbar{background:var(--sc-topbar);padding:0 24px;height:52px;border-bottom:1px solid var(--sc-border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,.04);}
.sc-page-title{font-weight:700;font-size:.95rem;color:var(--sc-text);}
.sc-topbar-right{display:flex;align-items:center;gap:12px;}
.sc-topbar-btn{background:none;border:none;color:#666;font-size:.88rem;cursor:pointer;padding:6px 10px;border-radius:6px;text-decoration:none;}
.sc-topbar-btn:hover{background:#f5f5f5;color:var(--sc-orange);}
.sc-content{flex:1;padding:20px 24px;}

.sc-alert{font-size:.85rem;border-radius:8px;padding:10px 14px;}

.sc-card{background:#fff;border-radius:10px;border:none;box-shadow:0 1px 4px rgba(0,0,0,.06);}
.sc-card .card-header{background:#fff;border-bottom:1px solid var(--sc-border);padding:12px 16px;font-weight:600;font-size:.88rem;border-radius:10px 10px 0 0;}

.sc-table th{font-weight:600;font-size:.78rem;color:#777;letter-spacing:.03em;border-bottom:1px solid var(--sc-border);padding:8px 12px;white-space:nowrap;}
.sc-table td{font-size:.83rem;padding:8px 12px;vertical-align:middle;border-bottom:1px solid #f8f8f8;}
.sc-table tr:hover td{background:#fafafa;}

.btn-sc-primary{background:var(--sc-orange);color:#fff;border:none;border-radius:7px;font-size:.82rem;padding:6px 14px;}
.btn-sc-primary:hover{background:#e06820;color:#fff;}
.btn-sc-outline{border:1px solid #ddd;background:#fff;color:#555;border-radius:7px;font-size:.82rem;padding:6px 14px;}
.btn-sc-outline:hover{border-color:var(--sc-orange);color:var(--sc-orange);}

.form-control,.form-select{border-radius:7px;font-size:.85rem;border-color:#dde1e7;}
.form-control:focus,.form-select:focus{border-color:var(--sc-orange);box-shadow:0 0 0 3px rgba(245,114,36,.12);}
.form-label{font-size:.8rem;font-weight:600;color:#555;margin-bottom:4px;}

.badge{border-radius:5px;font-weight:500;letter-spacing:.02em;}

.page-link{border-radius:6px!important;font-size:.8rem;margin:0 2px;border-color:#eee;}
.page-link:focus{box-shadow:none;}
.page-item.active .page-link{background:var(--sc-orange);border-color:var(--sc-orange);}
</style>
@await RenderSectionAsync("Styles", required: false)
</head>
<body>

@if(User.Identity?.IsAuthenticated == true){
<aside class="sc-sidebar">
  <div class="sc-logo">
    <div class="sc-logo-icon"><i class="fa fa-heart"></i></div>
    <div>
      <div class="sc-logo-text"><span style="color:#64B5F6;">Doki</span>Doki</div>
      <small>Seller Center</small>
    </div>
  </div>

  <nav class="sc-nav">
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")"
       asp-controller="Home" asp-action="Index">
      <i class="sc-icon fa fa-chart-line"></i>Dashboard
    </a>

    <div class="sc-group">Cửa hàng</div>
    <a class="sc-link" href="/Store" target="_blank">
      <i class="sc-icon fa fa-store"></i>Xem trang khách hàng
      <i class="fa fa-external-link fa-xs ms-auto text-muted"></i>
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Payment"?"active":"")"
       asp-controller="Payment" asp-action="History">
      <i class="sc-icon fa fa-receipt"></i>Đơn hàng
    </a>

    <div class="sc-group">Kho hàng</div>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Product"?"active":"")"
       asp-controller="Product" asp-action="Index">
      <i class="sc-icon fa fa-box"></i>Sản phẩm
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="ImportReceipt"&&ViewContext.RouteData.Values["action"]?.ToString()!="ExpiringBatches"?"active":"")"
       asp-controller="ImportReceipt" asp-action="Index">
      <i class="sc-icon fa fa-file-import"></i>Phiếu nhập kho
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="ImportReceipt"&&ViewContext.RouteData.Values["action"]?.ToString()=="ExpiringBatches"?"active":"")"
       asp-controller="ImportReceipt" asp-action="ExpiringBatches">
      <i class="sc-icon fa fa-triangle-exclamation"></i>Sắp hết hạn
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="ExportRequest"&&ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")"
       asp-controller="ExportRequest" asp-action="Index">
      <i class="sc-icon fa fa-file-export"></i>Yêu cầu xuất kho
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="ExportRequest"&&ViewContext.RouteData.Values["action"]?.ToString()=="MyRequests"?"active":"")"
       asp-controller="ExportRequest" asp-action="MyRequests">
      <i class="sc-icon fa fa-list"></i>Yêu cầu của tôi
    </a>

    <div class="sc-group">Danh mục</div>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Category"?"active":"")"
       asp-controller="Category" asp-action="Index">
      <i class="sc-icon fa fa-tags"></i>Danh mục SP
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Supplier"?"active":"")"
       asp-controller="Supplier" asp-action="Index">
      <i class="sc-icon fa fa-truck"></i>Nhà cung cấp
    </a>

    @if(User.IsInRole("Admin")){
    <div class="sc-group">Quản trị</div>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Account"&&ViewContext.RouteData.Values["action"]?.ToString()=="UserList"?"active":"")"
       asp-controller="Account" asp-action="UserList">
      <i class="sc-icon fa fa-users"></i>Tài khoản
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Permission"?"active":"")"
       asp-controller="Permission" asp-action="Index">
      <i class="sc-icon fa fa-shield-halved"></i>Phân quyền
    </a>
    <a class="sc-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="AuditLog"?"active":"")"
       asp-controller="AuditLog" asp-action="Index">
      <i class="sc-icon fa fa-clock-rotate-left"></i>Audit Log
    </a>
    }
  </nav>

  <div class="sc-user">
    <div class="sc-user-av">@(User.Identity!.Name?.Substring(0,1).ToUpper())</div>
    <div style="min-width:0;">
      <div class="sc-user-name">@User.Identity.Name</div>
      <div class="sc-user-role">@(User.IsInRole("Admin")?"Administrator":User.IsInRole("WarehouseStaff")?"Kho":"Sales")</div>
    </div>
    <form asp-controller="Account" asp-action="Logout" method="post" class="ms-auto">
      @Html.AntiForgeryToken()
      <button class="sc-topbar-btn" title="Đăng xuất"><i class="fa fa-right-from-bracket"></i></button>
    </form>
  </div>
</aside>

<div class="sc-main">
  <div class="sc-topbar">
    <div class="sc-page-title">
      @if(ViewData["Title"] != null){ <span>@ViewData["Title"]</span> }
    </div>
    <div class="sc-topbar-right">
      <a href="/Store" target="_blank" class="sc-topbar-btn" title="Mở cửa hàng">
        <i class="fa fa-store me-1"></i>Xem cửa hàng
      </a>
      <span style="color:#ddd;">|</span>
      <a asp-controller="Account" asp-action="UserList" class="sc-topbar-btn">
        <i class="fa fa-user me-1"></i>@User.Identity!.Name
      </a>
    </div>
  </div>

  <div class="sc-content">
    @if(TempData["Success"] != null){
      <div class="alert sc-alert alert-success alert-dismissible fade show">
        <i class="fa fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }
    @if(TempData["Error"] != null){
      <div class="alert sc-alert alert-danger alert-dismissible fade show">
        <i class="fa fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }
    @RenderBody()
  </div>
</div>

} else {
  <div class="container">@RenderBody()</div>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

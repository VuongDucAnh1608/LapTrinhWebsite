    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
        <div id="lzToast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-semibold" id="lzToastMsg"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const lzToastEl = document.getElementById('lzToast');
        const lzToastBS = bootstrap.Toast ? new bootstrap.Toast(lzToastEl) : null;
        function showToast(msg, ok=true) {
        document.getElementById('lzToastMsg').textContent = msg;
        lzToastEl.className = `toast align-items-center text-white border-0 ${ok?'bg-success':'bg-danger'}`;
        lzToastBS?.show();
        }

        async function addToCart(productId, qty=1) {
        const token = document.querySelector('[name=__RequestVerificationToken]')?.value || '';
        const res = await fetch('/Store/AddToCart', {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body:`productId=${productId}&quantity=${qty}&__RequestVerificationToken=${encodeURIComponent(token)}`
        });
        const d = await res.json();
        showToast(d.message, d.success);
        if(d.success) {
        document.querySelectorAll('.cart-count-badge').forEach(b => b.textContent=d.totalItems);
        if(!document.querySelector('.cart-count-badge') && d.totalItems>0) {
        document.querySelector('[href="/Store/Cart"]')?.insertAdjacentHTML('beforeend',
        `<span class="cart-count-badge">${d.totalItems}</span>`);
        }
        }
        return d;
        }

        let acTimer;
        const acInput = document.getElementById('globalSearch');
        const acDrop  = document.getElementById('acDrop');
        const isLoggedIn = @(User.Identity?.IsAuthenticated == true ? "true" : "false");

        if(acInput) {
        acInput.addEventListener('input', function() {
        clearTimeout(acTimer);
        const term = this.value.trim();
        if(term.length < 2){ acDrop.classList.add('d-none'); return; }

        acTimer = setTimeout(async () => {
        try {
        const res = await fetch(`/Product/Autocomplete?term=${encodeURIComponent(term)}`);
        if(!res.ok) throw new Error(`HTTP ${res.status}`);

        const data = await res.json();
        console.log('Autocomplete data:', data);

        if(!data || data.length === 0){
        acDrop.classList.add('d-none');
        return;
        }

        acDrop.innerHTML = data.map(p => `
        <div class="ac-item" onclick="location.href='/Store/ProductDetail/${p.id}'">
        <div class="ac-info flex-grow-1">
        <div class="ac-name">${p.label || 'N/A'}</div>
        <div class="ac-meta">
        ${p.category || 'N/A'} · ${p.unit || 'sp'}
        ${isLoggedIn && p.stock !== undefined ?
        `<span class="badge bg-light text-secondary border ms-1">Còn: ${p.stock}</span>` : ''}
        </div>
        </div>
        <div class="ac-price">${Number(p.price || 0).toLocaleString('vi-VN')} ₫</div>
        </div>
        `).join('') +
        (!isLoggedIn ? `<div class="ac-locked-hint"><i class="fa fa-lock fa-xs me-1"></i>Đăng nhập để xem tồn kho</div>` : '');

        acDrop.classList.remove('d-none');
        } catch(err) {
        console.error('Autocomplete error:', err);
        acDrop.classList.add('d-none');
        }
        }, 300);
        });

        acInput.addEventListener('keydown', e => {
        if(e.key === 'Enter') submitSearch();
        });
        }

        function submitSearch() {
        const q = acInput?.value.trim();
        if(q) window.location.href = `/Store?search=${encodeURIComponent(q)}`;
        }

        document.addEventListener('click', e => {
        if(!e.target.closest('#searchGroup')) acDrop?.classList.add('d-none');
        });

        function applyFilter() {
        const keyword = document.getElementById('filterKeyword')?.value || '';
        const category = document.querySelector('input[name="category"]:checked')?.value || '0';

        let url = '/Store?';
        if (keyword) url += `search=${encodeURIComponent(keyword)}&`;
        if (category !== '0') url += `categoryId=${category}`;

        window.location.href = url;
        }

        function clearFilter() {
        document.getElementById('filterKeyword').value = '';
        document.querySelector('input[name="category"][value="0"]').checked = true;
        window.location.href = '/Store';
        }
    </script>
    @Html.AntiForgeryToken()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
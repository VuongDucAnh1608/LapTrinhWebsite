@{ ViewData["Title"] = "Đã gửi email"; Layout = null; }
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/>
<title>Đã gửi email</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<style>body{background:linear-gradient(135deg,#1e2a3a,#2d4059);min-height:100vh;display:flex;align-items:center;}</style>
</head>
<body>
<div style="max-width:420px;width:100%;margin:auto;padding:16px;">
<div class="card border-0 shadow-lg rounded-4">
<div class="card-body p-4 text-center">
<i class="fa fa-envelope-circle-check fa-3x text-success mb-3"></i>
<h4 class="fw-bold">Kiểm tra email của bạn</h4>
<p class="text-muted">Nếu email tồn tại trong hệ thống, bạn sẽ nhận được liên kết đặt lại mật khẩu trong vài phút.</p>
<a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-2">Quay lại đăng nhập</a>
</div></div></div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
</body></html>

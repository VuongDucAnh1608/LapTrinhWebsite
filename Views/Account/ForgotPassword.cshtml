@model Website_QuanLyKhoHangThucPham.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Quên mật khẩu"; Layout = null; }
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/>
<title>Quên mật khẩu</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<style>body{background:linear-gradient(135deg,#1e2a3a,#2d4059);min-height:100vh;display:flex;align-items:center;}</style>
</head>
<body>
<div style="max-width:420px;width:100%;margin:auto;padding:16px;">
<div class="card border-0 shadow-lg rounded-4">
<div class="card-body p-4">
<h4 class="fw-bold mb-1">Quên mật khẩu</h4>
<p class="text-muted small mb-3">Nhập email để nhận liên kết đặt lại mật khẩu.</p>
<form asp-action="ForgotPassword" method="post">
@Html.AntiForgeryToken()
<div class="mb-3">
<label asp-for="Email" class="form-label fw-semibold"></label>
<input asp-for="Email" class="form-control" placeholder="email@example.com" />
<span asp-validation-for="Email" class="text-danger small"></span>
</div>
<button type="submit" class="btn btn-primary w-100">Gửi liên kết đặt lại</button>
<a asp-action="Login" class="btn btn-outline-secondary w-100 mt-2">Quay lại đăng nhập</a>
</form>
</div></div></div>
</body></html>

@model Website_QuanLyKhoHangThucPham.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Đăng nhập"; Layout = null; }
<!DOCTYPE html><html lang="vi"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Đăng nhập — DokiDoki</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
body{background:linear-gradient(135deg,#1e2a3a 0%,#2d4059 100%);min-height:100vh;display:flex;align-items:center;}
.login-box{max-width:420px;width:100%;margin:auto;}
.card{border:none;border-radius:18px;box-shadow:0 24px 60px rgba(0,0,0,.3);}
.card-header{background:linear-gradient(135deg,#1e2a3a,#2d4059);border-radius:18px 18px 0 0;padding:30px;text-align:center;}
.card-body{padding:28px 32px;}
.btn-login{background:linear-gradient(135deg,#4fc3f7,#0288d1);border:none;font-weight:600;}
.btn-google{background:#fff;color:#333;border:1px solid #ddd;font-weight:600;}
.btn-google:hover{background:#f5f5f5;}
.divider{display:flex;align-items:center;gap:10px;color:#aaa;font-size:.8rem;margin:16px 0;}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:#e0e0e0;}
.form-control:focus{box-shadow:0 0 0 3px rgba(79,195,247,.2);border-color:#4fc3f7;}
.register-link{text-align:center;margin-top:16px;font-size:.85rem;color:#999;}
.register-link a{color:#4fc3f7;text-decoration:none;font-weight:600;}
.register-link a:hover{text-decoration:underline;}
</style>
</head>
<body>
<div class="login-box px-3">
<div class="card">
<div class="card-header">
    <i class="fa fa-warehouse fa-2x text-info mb-3"></i>
    <h4 class="text-white fw-bold mb-1">Warehouse Management</h4>
    <p class="text-white-50 small mb-0">Hệ thống quản lý kho hàng thực phẩm</p>
</div>

<div class="card-body">
    @if (!ViewData.ModelState.IsValid)
    {<div class="alert alert-danger py-2 small"><div asp-validation-summary="All"></div></div>}

    @if(TempData["Success"] != null){
    <div class="alert alert-success py-2 small"><i class="fa fa-check-circle me-1"></i>@TempData["Success"]</div>
    }
    <form asp-action="Login" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl"/>
    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold small"></label>
        <div class="input-group"><span class="input-group-text"><i class="fa fa-envelope text-muted"></i></span>
        <input asp-for="Email" class="form-control" placeholder="admin@warehouse.com"/></div>
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Password" class="form-label fw-semibold small"></label>
        <div class="input-group"><span class="input-group-text"><i class="fa fa-lock text-muted"></i></span>
        <input asp-for="Password" class="form-control" placeholder="••••••••"/></div>
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check"><input asp-for="RememberMe" class="form-check-input"/>
        <label asp-for="RememberMe" class="form-check-label small">Ghi nhớ</label></div>
        <a asp-action="ForgotPassword" class="small text-info text-decoration-none">Quên mật khẩu?</a>
    </div>
    <button type="submit" class="btn btn-login btn-primary w-100 py-2 text-white">
        <i class="fa fa-right-to-bracket me-2"></i>Đăng nhập
    </button>
    </form>

    <div class="register-link">
        Chưa có tài khoản? <a asp-action="RegisterCustomer">Đăng ký ngay</a>
    </div>

    <div class="divider">hoặc</div>

    <a href="/Account/LoginWithGoogle" class="btn btn-google w-100 py-2">
        <svg width="18" height="18" viewBox="0 0 48 48" class="me-2" style="vertical-align:text-bottom">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        Tiếp tục với Google
    </a>
</div></div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body></html>

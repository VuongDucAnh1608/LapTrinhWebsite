@model Website_QuanLyKhoHangThucPham.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Chỉnh sửa thông tin"; Layout = "~/Views/Shared/Customer_Layout.cshtml"; }

<div class="container my-4" style="max-width:500px;">
  <div class="card">
    <div class="card-header fw-bold">
      <i class="fa fa-pen me-2 text-primary"></i>Chỉnh sửa thông tin cá nhân
    </div>
    <div class="card-body">
      @if (TempData["Success"] != null) {
      <div class="alert alert-success py-2 small"><i class="fa fa-check-circle me-1"></i>@TempData["Success"]</div>
      }
      <form asp-action="EditProfile" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
        <div class="mb-3">
          <label asp-for="FullName" class="form-label fw-semibold small"></label>
          <input asp-for="FullName" class="form-control"/>
          <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold small">Email</label>
          <input value="@User.Identity?.Name" class="form-control" disabled/>
          <div class="form-text">Email không thể thay đổi.</div>
        </div>
        <div class="mb-3">
          <label asp-for="PhoneNumber" class="form-label fw-semibold small"></label>
          <input asp-for="PhoneNumber" class="form-control" placeholder="0901 234 567"/>
          <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary"><i class="fa fa-save me-1"></i>Lưu thay đổi</button>
          <a href="/Store" class="btn btn-outline-secondary">Hủy</a>
        </div>
      </form>
    </div>
  </div>
</div>

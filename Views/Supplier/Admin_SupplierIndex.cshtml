@model IEnumerable<Website_QuanLyKhoHangThucPham.Models.Supplier>
@{ ViewData["Title"] = "Nhà cung cấp"; }
<div class="d-flex justify-content-between align-items-center mb-4">
  <div><h5 class="fw-bold mb-0">Nhà cung cấp</h5><small class="text-muted">@Model.Count() nhà cung cấp</small></div>
  <a asp-action="Create" class="btn btn-sc-primary btn-sm"><i class="fa fa-plus me-1"></i>Thêm NCC</a>
</div>
<div class="sc-card">
  <table class="table sc-table mb-0">
    <thead><tr><th>Tên</th><th>Mã</th><th>Liên hệ</th><th>Điện thoại</th><th>Email</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
    <tbody>
    @foreach(var s in Model){
    <tr>
      <td class="fw-semibold">@s.Name</td>
      <td><span class="badge bg-light text-dark border">@s.Code</span></td>
      <td>@s.ContactPerson</td>
      <td>@s.Phone</td>
      <td style="font-size:.8rem;">@s.Email</td>
      <td><span class="badge @(s.IsActive?"bg-success":"bg-secondary")">@(s.IsActive?"Hoạt động":"Tắt")</span></td>
      <td class="text-end">
        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-sc-outline me-1"><i class="fa fa-pen"></i></a>
        <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa nhà cung cấp này?')">
          @Html.AntiForgeryToken()
          <button class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i></button>
        </form>
      </td>
    </tr>
    }
    </tbody>
  </table>
</div>

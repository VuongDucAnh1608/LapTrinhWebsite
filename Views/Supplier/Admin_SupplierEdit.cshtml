@model Website_QuanLyKhoHangThucPham.ViewModels.SupplierViewModel
@{ ViewData["Title"] = "Sửa nhà cung cấp"; }
<div class="sc-card" style="max-width:680px;">
  <div class="card-header"><i class="fa fa-pen me-2" style="color:var(--sc-orange);"></i>Chỉnh sửa nhà cung cấp</div>
  <div class="p-4">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
      <div class="row g-3">
        <div class="col-md-8"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"/><span asp-validation-for="Name" class="text-danger small"></span></div>
        <div class="col-md-4"><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="ContactPerson" class="form-label"></label><input asp-for="ContactPerson" class="form-control"/></div>
        <div class="col-12"><label asp-for="Address" class="form-label"></label><input asp-for="Address" class="form-control"/></div>
        <div class="col-12 form-check ms-2"><input asp-for="IsActive" class="form-check-input"/><label asp-for="IsActive" class="form-check-label">Kích hoạt</label></div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-sc-primary"><i class="fa fa-save me-1"></i>Cập nhật</button>
        <a asp-action="Index" class="btn btn-sc-outline">Hủy</a>
      </div>
    </form>
  </div>
</div>

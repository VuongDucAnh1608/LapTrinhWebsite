@model Website_QuanLyKhoHangThucPham.Models.AuditLog
@{ ViewData["Title"] = "Chi tiết Audit Log"; }
<div class="card" style="max-width:700px;">
<div class="card-header fw-semibold"><i class="fa fa-clock-rotate-left me-2"></i>Chi tiết nhật ký #@Model.Id</div>
<div class="card-body">
<table class="table table-borderless table-sm mb-0">
<tbody>
    <tr><th style="width:140px" class="text-muted">Thời gian</th><td class="fw-semibold">@Model.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td></tr>
    <tr><th class="text-muted">Người dùng</th><td class="fw-semibold">@Model.UserName</td></tr>
    <tr><th class="text-muted">User ID</th><td class="text-muted small">@Model.UserId</td></tr>
    <tr><th class="text-muted">Action</th><td><span class="badge bg-primary">@Model.Action</span></td></tr>
    <tr><th class="text-muted">Đối tượng</th><td>@Model.EntityName</td></tr>
    <tr><th class="text-muted">Entity ID</th><td>@Model.EntityId</td></tr>
    <tr><th class="text-muted">Mô tả</th><td>@Model.Description</td></tr>
    <tr><th class="text-muted">IP Address</th><td>@Model.IpAddress</td></tr>
    @if (!string.IsNullOrEmpty(Model.OldValues))
    {
        <tr><th class="text-muted">Giá trị cũ</th><td><pre class="small bg-light p-2 rounded">@Model.OldValues</pre></td></tr>
    }
    @if (!string.IsNullOrEmpty(Model.NewValues))
    {
        <tr><th class="text-muted">Giá trị mới</th><td><pre class="small bg-light p-2 rounded">@Model.NewValues</pre></td></tr>
    }
</tbody>
</table>
</div></div>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Quay lại</a>
</div>
